---
import Base from "../layouts/Base.astro";
import { formatShortDate, getPublishedPosts } from "../lib/posts";

const posts = await getPublishedPosts();
---

<Base title="Against Uncertainty" description="Essays by Alex Janiak.">
	<h1 class="page-title">Blog</h1>
	<ul class="post-list">
		{posts.map((post) => (
			<li class="post-item">
				<div class="post-item-head">
					<a class="post-item-title" href={`/blog/${post.id}/`}>{post.data.title}</a>
					<time class="post-item-date" datetime={post.data.date.toISOString()}>{formatShortDate(post.data.date)}</time>
				</div>
				{post.data.description && <p class="post-item-description">{post.data.description}</p>}
			</li>
		))}
	</ul>
</Base>
