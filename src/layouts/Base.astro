---
import "../styles/global.css";

type Props = {
	title?: string;
	description?: string;
};

const {
	title = "Aelix's Blog",
	description = "Essays on decision markets, futarchy, philosophy, and practical agency.",
} = Astro.props;

const pageTitle = title === "Aelix's Blog" ? title : `${title} | Aelix's Blog`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://aelix.dev").toString();
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#fffff8" />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<link rel="alternate" href="/rss.xml" type="application/rss+xml" title="Aelix RSS" />
		<link rel="icon" href="/og-image.jpg" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="Aelix" />
		<meta property="og:image" content="/og-image.jpg" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:creator" content="@waniak_" />
		<script is:inline>
			(() => {
				try {
					const stored = localStorage.getItem("theme");
					const system = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
					document.documentElement.dataset.theme = stored || system;
				} catch {
					document.documentElement.dataset.theme = "light";
				}
			})();
		</script>
	</head>
	<body>
		<a class="skip-link" href="#content">Skip to content</a>
		<div class="site-shell">
			<aside class="left-rail">
				<nav class="site-nav" aria-label="Primary navigation">
					<a href="/">Blog</a>
					<a href="/about/">About</a>
				</nav>
				<hr class="rail-divider" />
				<div class="social-links" aria-label="Contact links">
					<a href="https://x.com/waniak_" aria-label="X">
						<svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.47l8.6-9.83L0 1.15h7.59l5.24 6.93 6.07-6.93Zm-1.29 19.5h2.04L6.49 3.24H4.3l13.31 17.41Z" />
						</svg>
					</a>
					<a href="https://www.linkedin.com/in/alexander-janiak" aria-label="LinkedIn">
						<svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.86-3.04-1.85 0-2.14 1.45-2.14 2.95v5.66H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0Z" />
						</svg>
					</a>
					<a href="https://www.lesswrong.com/users/aelix" aria-label="LessWrong">
						<svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M12 1.8 2.7 6.95v10.1L12 22.2l9.3-5.15V6.95L12 1.8Zm0 2.55 6.7 3.7-6.7 3.68-6.7-3.68L12 4.35Zm-7.05 5.5 5.98 3.3v6.02l-5.98-3.31V9.85Zm8.12 9.32v-6.02l5.98-3.3v6.01l-5.98 3.31Z" />
						</svg>
					</a>
					<a href="https://aelix.substack.com" aria-label="Substack">
						<svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M22.54 8.24H1.46V5.41h21.08v2.83ZM1.46 10.81V24L12 18.11 22.54 24V10.81H1.46ZM22.54 0H1.46v2.84h21.08V0Z" />
						</svg>
					</a>
				</div>
			</aside>
			<div class="content-column">
				<button class="theme-toggle" type="button" aria-label="Toggle dark mode" aria-pressed="false">
					<span class="theme-dot" aria-hidden="true"></span>
					<span data-theme-label>Dark</span>
				</button>
				<main id="content">
					<slot />
				</main>
				<footer class="scroll-footer" aria-hidden="true"></footer>
			</div>
		</div>
		<script is:inline>
			(() => {
				const button = document.querySelector(".theme-toggle");
				const label = document.querySelector("[data-theme-label]");

				function paint(theme) {
					document.documentElement.dataset.theme = theme;
					button?.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
					if (label) label.textContent = theme === "dark" ? "Light" : "Dark";
					try {
						localStorage.setItem("theme", theme);
					} catch {}
				}

				paint(document.documentElement.dataset.theme || "light");
				button?.addEventListener("click", () => {
					paint(document.documentElement.dataset.theme === "dark" ? "light" : "dark");
				});
			})();
		</script>
	</body>
</html>
