---
layout: layouts/base.njk
---
<style>{% include "node_modules/prismjs/themes/prism-okaidia.css" %}</style>
<style>{% include "css/prism-diff.css" %}</style>
<article class="post">
	<header class="article-header">
		<p class="eyebrow">Essay</p>
		<h1>{{ title }}</h1>
		{%- if description %}
		<p class="subtitle">{{ description }}</p>
		{%- endif %}
		<p class="byline">
			Alex Janiak
			<span aria-hidden="true">/</span>
			<time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate("LLLL d, yyyy") }}</time>
			{%- set filteredTags = tags | filterTagList %}
			{%- if filteredTags.length %}
			<span aria-hidden="true">/</span>
			Filed under
			{%- for tag in filteredTags %}
				{%- set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
				<a href="{{ tagUrl }}" class="post-tag">{{ tag }}</a>{%- if not loop.last %}, {% endif %}
			{%- endfor %}
			{%- endif %}
		</p>
	</header>

	<section class="article-body">
		{{ content | safe }}
	</section>

	{%- if collections.posts %}
	{%- set previousPost = collections.posts | getPreviousCollectionItem %}
	{%- set nextPost = collections.posts | getNextCollectionItem %}
	{%- if nextPost or previousPost %}
	<nav class="links-nextprev" aria-label="Previous and next essays">
		{%- if previousPost %}<a class="links-nextprev-prev" href="{{ previousPost.url }}"><span>Previous</span>{{ previousPost.data.title }}</a>{% endif %}
		{%- if nextPost %}<a class="links-nextprev-next" href="{{ nextPost.url }}"><span>Next</span>{{ nextPost.data.title }}</a>{% endif %}
	</nav>
	{%- endif %}
	{%- endif %}
</article>
