---js
const eleventyNavigation = {
	key: "Blog",
	order: 2
};
---
<article class="archive-page">
	<header class="article-header">
		<p class="eyebrow">Index</p>
		<h1>Blog</h1>
		<p class="subtitle">Selected essays, newest first.</p>
	</header>

	<section class="archive-section">
		{% set groupedPosts = collections.posts | groupByMonth %}
		{%- for group in groupedPosts %}
		<h3 class="month-heading">{{ group.label }}</h3>
		{% set postslist = group.posts %}
		{% include "postslist.njk" %}
		{%- endfor %}
	</section>
</article>
